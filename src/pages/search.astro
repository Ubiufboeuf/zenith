---
import Layout from '@/layouts/Layout.astro'
import { ResultsSection as Results } from '@/components/search/ResultsSection'
import { SearchSection } from '@/components/search/SearchSection'
import { getProducts } from '@/services/productsService'

const firstResults = await getProducts()
---

<Layout tabBar>
  <div class='h-fit w-full min-h-full flex flex-col p-6 gap-5'>
		<header class='mobile:not-xs:hidden h-fit sm:h-18 flex flex-col justify-center gap-1'>
			<h1 class='text-2xl font-semibold text-light'>Buscar Productos</h1>
			<span class='text-sm text-neutral-400'>Consulta rápida de productos por código, nombre o categoría</span>
		</header>
		<SearchSection client:load />
		<Results client:load />
	</div>
</Layout>